# ─────────────────────────────────────────────
# VENTO — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# NUNCA commitear .env.local a git
# ─────────────────────────────────────────────

# Base de datos (PostgreSQL local para desarrollo)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vento_dev"

# Base de datos para tests (separada — se limpia en cada run)
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/vento_test"

# Auth.js — generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui-generalo-con-openssl"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (modo test — claves del dashboard stripe.com)
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # generado con: stripe listen --print-secret

# Resend (emails transaccionales — resend.com)
RESEND_API_KEY="re_..."

# Cloudflare R2 (imágenes de productos)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="vento-products"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VENTO"
